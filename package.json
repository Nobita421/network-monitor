{
  "name": "netmonitor-pro",
  "version": "1.0.0",
  "description": "A Windows desktop application to monitor network activity.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:no-geoip": "node ./scripts/clean-build-output.mjs && tsc && vite build && electron-builder --publish never",
    "build": "pnpm geoip:update:best-effort && pnpm build:no-geoip",
    "package:dir": "pnpm geoip:update:best-effort && node ./scripts/clean-build-output.mjs && tsc && vite build && electron-builder --dir --publish never",
    "test": "node ./scripts/run-vitest.mjs",
    "test:strict": "node ./scripts/run-vitest.mjs --testTimeout=30000 --hookTimeout=30000 --teardownTimeout=30000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron",
    "geoip:update": "node ./scripts/update-geoip-data.mjs --strict",
    "geoip:update:best-effort": "node ./scripts/update-geoip-data.mjs",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm"
  },
  "build": {
    "compression": "maximum",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "removePackageScripts": true,
    "electronLanguages": [
      "en-US"
    ],
    "files": [
      "package.json",
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!release/**/*",
      "!build/**/*",
      "!src/**/*",
      "!electron/**/*",
      "!public/**/*",
      "!scripts/**/*",
      "!*.md",
      "!*.yml",
      "!*.yaml",
      "!.git/**/*",
      "!.github/**/*",
      "!.vscode/**/*",
      "!.opencode/**/*",
      "!.antigravity/**/*"
    ],
    "win": {
      "icon": "icon.ico"
    },
    "extraResources": [
      {
        "from": "node_modules/geoip-lite/data",
        "to": "data"
      }
    ]
  },
  "keywords": [
    "network",
    "monitor",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@maxmind/geoip2-node": "^6.3.4",
    "@types/three": "^0.182.0",
    "clsx": "^2.1.0",
    "dexie": "^4.2.1",
    "geoip-lite": "^1.4.10",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-globe.gl": "^2.37.0",
    "recharts": "^2.12.0",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "^2.2.1",
    "three": "^0.182.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.18",
    "baseline-browser-mapping": "^2.10.20",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1",
      "@xmldom/xmldom": "^0.9.9",
      "ajv": "^6.14.0",
      "brace-expansion@1.1.12": "^1.1.13",
      "brace-expansion@2.0.2": "^2.0.3",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "minimatch@3.1.2": "^3.1.5",
      "minimatch@5.1.6": "^5.1.8",
      "minimatch@9.0.5": "^9.0.7",
      "picomatch": "^2.3.2",
      "preact": "^10.29.1",
      "rollup": "^4.59.0"
    }
  }
}
